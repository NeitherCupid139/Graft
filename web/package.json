{
  "name": "graft-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:mock": "vite --mode mock",
    "dev:open": "vite --open --mode development",
    "build": "bun run typecheck && vite build --mode release",
    "build:test": "vite build --mode test",
    "build:type": "bun run typecheck",
    "lint": "eslint --ext .vue,.js,.jsx,.ts,.tsx ./ --max-warnings 0",
    "lint:i18n": "bun run scripts/check-i18n-governance.ts",
    "lint:fix": "eslint --ext .vue,.js,.jsx,.ts,.tsx ./ --max-warnings 0 --fix",
    "stylelint": "stylelint \"src/**/*.{html,vue,css,sass,less}\"",
    "stylelint:fix": "stylelint --fix \"src/**/*.{html,vue,css,sass,less}\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "deadcode:check": "knip --config knip.config.ts --include files,exports,dependencies",
    "deadcode:fix": "knip --config knip.config.ts --include exports,dependencies --fix",
    "dupcode:check": "jscpd --config .jscpd.json",
    "hygiene:check": "bun run deadcode:check && bun run dupcode:check",
    "contract:check:changed": "sh ../scripts/run_python.sh ../scripts/magic_value/check_magic_values.py --mode changed",
    "openapi:types": "mkdir -p src/contracts/openapi/generated && bunx openapi-typescript ../openapi/openapi.yaml -o src/contracts/openapi/generated/schema.ts && bunx prettier --write src/contracts/openapi/generated/schema.ts",
    "openapi:types:check": "sh -c 'mkdir -p .tmp; tmp=.tmp/openapi-types-check.ts; trap \"rm -f \\\"$tmp\\\"\" EXIT; bunx openapi-typescript ../openapi/openapi.yaml -o \"$tmp\" >/dev/null && bunx prettier --config .prettierrc.json --ignore-path .prettierignore --no-error-on-unmatched-pattern --write \"$tmp\" >/dev/null && cmp -s \"$tmp\" src/contracts/openapi/generated/schema.ts'",
    "openapi:frontend-governance:check": "bun run scripts/check-openapi-frontend-governance.ts",
    "check": "bun run format:check && bun run typecheck && bun run openapi:frontend-governance:check && bun run lint:i18n && bun run lint && bun run stylelint && bun run hygiene:check && bun run test:run && bun run build"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.0",
    "axios": "^1.16.1",
    "consola": "^3.4.2",
    "echarts": "5.4.3",
    "lodash": "^4.17.23",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.19.1",
    "tvision-color": "^1.6.0",
    "vue": "^3.5.18",
    "vue-i18n": "^9.9.1",
    "vue-router": "^4.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.27.0",
    "@types/lodash": "^4.17.24",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^22.15.3",
    "@types/nprogress": "^0.2.3",
    "@unocss/vite": "^66.5.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vitest/coverage-v8": "^3.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.33.0",
    "eslint-plugin-vue-scoped-css": "^2.10.0",
    "globals": "^16.0.0",
    "jscpd": "4.2.3",
    "jsdom": "^26.1.0",
    "knip": "6.14.2",
    "less": "^4.2.0",
    "lint-staged": "^16.0.0",
    "mockjs": "^1.1.0",
    "openapi-typescript": "7.13.0",
    "postcss-html": "^1.8.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "unocss": "^66.5.1",
    "vite": "^5.4.19",
    "vite-plugin-mock": "^3.0.1",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{html,vue,css,sass,less}": [
      "stylelint --fix"
    ],
    "*.{css,less,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
