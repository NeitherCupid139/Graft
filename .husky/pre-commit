#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
scanner="$repo_root/scripts/magic_value/check_magic_values.py"
python_runner="$repo_root/scripts/run_python.sh"
migration_version_checker="$repo_root/scripts/check_migration_versions.py"
run_lint_staged=0
run_i18n_lint=0

changed_files="$(git diff --cached --name-only --diff-filter=ACMR)"
while IFS= read -r path; do
  case "$path" in
    web/*.js|web/*.mjs|web/*.cjs|web/*.jsx|web/*.ts|web/*.mts|web/*.cts|web/*.tsx|web/*.vue|web/*.html|web/*.css|web/*.sass|web/*.less|web/*.md|web/*.json|web/*.yml|web/*.yaml)
      run_lint_staged=1
      ;;
  esac

  case "$path" in
    web/src/*|web/scripts/check-i18n-governance.ts|web/package.json)
      run_i18n_lint=1
      ;;
  esac
done <<EOF
$changed_files
EOF

if [ "$run_lint_staged" -eq 1 ]; then
  cd "$repo_root/web"
  ./node_modules/.bin/lint-staged
  bun run density:check
  if [ "$run_i18n_lint" -eq 1 ]; then
    bun run lint:i18n
  fi
else
  echo "lint-staged: skip pre-commit check (no staged web files matched configured tasks)"
fi

if [ ! -f "$scanner" ]; then
  echo "contract governance: skip pre-commit check (missing $scanner)"
  exit 0
fi

if [ ! -f "$python_runner" ]; then
  echo "contract governance: missing python runner $python_runner" >&2
  exit 1
fi

cd "$repo_root"
sh "$python_runner" "$scanner" --mode changed

if [ ! -f "$migration_version_checker" ]; then
  echo "migration version gate: missing checker $migration_version_checker" >&2
  exit 1
fi

sh "$python_runner" "$migration_version_checker" --mode changed
