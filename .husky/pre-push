#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
python_runner="$repo_root/scripts/run_python.sh"
migration_version_checker="$repo_root/scripts/check_migration_versions.py"

resolve_fetch_target() {
  ref="$1"

  case "$ref" in
    refs/remotes/origin/*)
      printf '%s\n' "${ref#refs/remotes/origin/}"
      ;;
    origin/*)
      printf '%s\n' "${ref#origin/}"
      ;;
    refs/heads/*)
      printf '%s\n' "${ref#refs/heads/}"
      ;;
    refs/*)
      printf '%s\n' "$ref"
      ;;
    *)
      printf '%s\n' "$ref"
      ;;
  esac
}

normalize_base_ref() {
  ref="$1"

  case "$ref" in
    refs/remotes/*)
      printf '%s\n' "$ref"
      ;;
    refs/heads/*)
      printf 'refs/remotes/origin/%s\n' "${ref#refs/heads/}"
      ;;
    origin/*)
      printf 'refs/remotes/%s\n' "$ref"
      ;;
    refs/*)
      printf '%s\n' "$ref"
      ;;
    *)
      printf 'refs/remotes/origin/%s\n' "$ref"
      ;;
  esac
}

if [ "${GRAFT_LINT_BASE_REF:-}" != "" ]; then
  base_ref="$GRAFT_LINT_BASE_REF"
else
  if ! origin_head_ref="$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null)"; then
    echo "backend lint gate: cannot resolve origin/HEAD." >&2
    echo "backend lint gate: run 'git remote set-head origin -a' or set GRAFT_LINT_BASE_REF before pushing." >&2
    exit 1
  fi
  base_ref="${origin_head_ref#refs/remotes/}"
fi

base_ref="$(normalize_base_ref "$base_ref")"
fetch_target="$(resolve_fetch_target "$base_ref")"

if ! git fetch --quiet origin "$fetch_target"; then
  echo "backend lint gate: failed to fetch base branch '$fetch_target' from origin." >&2
  echo "backend lint gate: run 'git fetch origin $fetch_target' and retry." >&2
  exit 1
fi

if ! git rev-parse --verify --quiet "$base_ref^{commit}" >/dev/null; then
  echo "backend lint gate: base ref '$base_ref' is not available locally after fetch." >&2
  echo "backend lint gate: run 'git fetch origin $fetch_target' or set GRAFT_LINT_BASE_REF to a reachable base ref." >&2
  exit 1
fi

export GRAFT_LINT_BASE_REF="$base_ref"

if [ ! -f "$python_runner" ]; then
  echo "migration version gate: missing python runner $python_runner" >&2
  exit 1
fi

if [ ! -f "$migration_version_checker" ]; then
  echo "migration version gate: missing checker $migration_version_checker" >&2
  exit 1
fi

cd "$repo_root"
sh "$python_runner" "$migration_version_checker" --mode all

changed_files="$(git diff --name-only "$base_ref...HEAD")"
run_i18n_lint=0
while IFS= read -r path; do
  case "$path" in
    web/src/*|web/scripts/check-i18n-governance.ts|web/package.json)
      run_i18n_lint=1
      ;;
  esac
done <<EOF
$changed_files
EOF

if printf '%s\n' "$changed_files" | grep -q '^web/'; then
  (
    cd "$repo_root/web"
    if [ "$run_i18n_lint" -eq 1 ]; then
      bun run lint:i18n
    fi
    bun run hygiene:check
  )
else
  echo "web hygiene gate: no web/** changes detected; skipping."
fi

cd "$repo_root/server"
go run ./cmd/graft validate backend --stage lint

if printf '%s\n' "$changed_files" | grep -q '^server/'; then
  go run ./cmd/graft validate backend --stage buildtest
else
  echo "backend buildtest gate: no server/** changes detected; skipping."
fi
