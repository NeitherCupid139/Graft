GRAFT_APP_NAME=graft
GRAFT_APP_ENV=local
GRAFT_HTTP_ADDR=:8080
GRAFT_DATABASE_DRIVER=postgres
GRAFT_DATABASE_URL=postgres://graft:graft@localhost:5432/graft?sslmode=disable
GRAFT_REDIS_ADDR=localhost:6379
GRAFT_REDIS_PASSWORD=
GRAFT_REDIS_DB=0
GRAFT_I18N_DEFAULT_LOCALE=zh-CN
GRAFT_I18N_FALLBACK_LOCALE=zh-CN
GRAFT_I18N_SUPPORTED_LOCALES=zh-CN,en-US
GRAFT_LOG_LEVEL=info
# 日志格式：auto|console|json。auto 下 local/dev/test 使用 console，prod/staging/未知环境使用 json。
GRAFT_LOG_FORMAT=auto
# 日志级别颜色：auto|always|never。仅 console 格式生效；auto 下本地类环境启用颜色，生产类环境无颜色。
GRAFT_LOG_COLOR=auto
# Gin 运行模式：auto|debug|release|test。auto 下 local/dev=debug，test=test，prod/staging/未知环境=release。
GRAFT_GIN_MODE=auto
# Access Log 控制台输出：auto|always|never|error_only。auto 下 local/dev=error_only，prod/staging/test/未知环境=never；持久化不受影响。
GRAFT_ACCESS_LOG_CONSOLE=auto
# 慢请求阈值，单位毫秒；当 Access Log 控制台策略为 error_only 时，4xx/5xx 或超过该阈值的请求会输出到控制台。
GRAFT_ACCESS_LOG_SLOW_THRESHOLD_MS=1000
# 本地开发也必须至少配置 GRAFT_AUTH_JWT_SECRET 或 GRAFT_AUTH_SIGNING_KEY 之一；该示例值仅用于本地开发演示，生产环境必须替换。
GRAFT_AUTH_JWT_SECRET=local-demo-jwt-signing-key-2026-please-change
