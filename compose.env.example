# Release images published by this repository's tag workflow.
GRAFT_SERVER_IMAGE=ghcr.io/gewuyou/graft-server
GRAFT_WEB_IMAGE=ghcr.io/gewuyou/graft-web
GRAFT_IMAGE_TAG=latest

# PostgreSQL bootstrap database credentials used by the bundled postgres service.
POSTGRES_DB=graft
POSTGRES_USER=graft
POSTGRES_PASSWORD=change-me

# Required runtime signing secret for the server auth module. Replace in every real deployment.
GRAFT_AUTH_JWT_SECRET=change-me

# Optional runtime overrides. Leave commented to use the server or web image defaults.

# Application environment. Default: production. Controls server retention defaults, docs exposure, and runtime mode.
# GRAFT_APP_ENV=production

# Server listen address inside the container. Default: :8080.
# GRAFT_HTTP_ADDR=:8080

# Server port exposed to other compose services. Keep aligned with GRAFT_HTTP_ADDR.
# GRAFT_SERVER_EXPOSE_PORT=8080

# OpenAPI docs exposure. Default in production: false.
# GRAFT_DOCS_ENABLED=false

# Server log level. Default: info.
# GRAFT_LOG_LEVEL=info

# Server log encoder. Default: auto.
# GRAFT_LOG_FORMAT=auto

# Server log color policy for console logs. Default: auto.
# GRAFT_LOG_COLOR=auto

# Access log console emission policy. Default: auto.
# GRAFT_ACCESS_LOG_CONSOLE=auto

# Slow request threshold in milliseconds for access log console output. Default: 1000.
# GRAFT_ACCESS_LOG_SLOW_THRESHOLD_MS=1000

# Access log retention. Production default: 720h.
# GRAFT_HTTPX_ACCESS_LOG_RETENTION=720h

# Audit log retention. Production default: 4320h.
# GRAFT_AUDIT_LOG_RETENTION=4320h

# Whether application logs persist to PostgreSQL. Default: true.
# GRAFT_LOG_APP_LOG_PERSIST=true

# Application log retention. Production default: 336h.
# GRAFT_LOG_APP_LOG_RETENTION=336h

# PostgreSQL connection pool. Defaults: 25 / 10 / 1h / 30m.
# GRAFT_DATABASE_MAX_OPEN_CONNS=25
# GRAFT_DATABASE_MAX_IDLE_CONNS=10
# GRAFT_DATABASE_CONN_MAX_LIFETIME=1h
# GRAFT_DATABASE_CONN_MAX_IDLE_TIME=30m

# Redis auth and DB selection. Defaults: empty password and DB 0.
# GRAFT_REDIS_PASSWORD=
# GRAFT_REDIS_DB=0

# Redis connection pool. Default 0 values defer to go-redis behavior.
# GRAFT_REDIS_POOL_SIZE=0
# GRAFT_REDIS_MIN_IDLE_CONNS=0
# GRAFT_REDIS_MAX_IDLE_CONNS=0
# GRAFT_REDIS_MAX_ACTIVE_CONNS=0
# GRAFT_REDIS_POOL_TIMEOUT=0
# GRAFT_REDIS_CONN_MAX_IDLE_TIME=0
# GRAFT_REDIS_CONN_MAX_LIFETIME=0

# i18n defaults. Defaults: zh-CN fallback with zh-CN,en-US support.
# GRAFT_I18N_DEFAULT_LOCALE=zh-CN
# GRAFT_I18N_FALLBACK_LOCALE=zh-CN
# GRAFT_I18N_SUPPORTED_LOCALES=zh-CN,en-US

# Token and refresh-session behavior. Defaults: 15m access token, 168h refresh token.
# GRAFT_AUTH_ACCESS_TOKEN_TTL=15m
# GRAFT_AUTH_REFRESH_TOKEN_TTL=168h

# Refresh cookie settings. Defaults: graft_refresh_token / false / lax / /.
# GRAFT_AUTH_REFRESH_COOKIE_NAME=graft_refresh_token
# GRAFT_AUTH_REFRESH_COOKIE_SECURE=false
# GRAFT_AUTH_REFRESH_COOKIE_SAME_SITE=lax
# GRAFT_AUTH_REFRESH_COOKIE_PATH=/

# Optional module allow list. Empty means all compiled modules stay enabled.
# GRAFT_MODULES_ENABLED=

# Web runtime upstream used by the nginx container. Default: http://server:8080.
# GRAFT_SERVER_UPSTREAM=http://server:8080

# Optional container-management feature gates. Keep disabled unless you also mount docker.sock via compose.ops-container.yml.
# GRAFT_OPS_CONTAINER_RUNTIME_ENABLED=false
# GRAFT_OPS_CONTAINER_RUNTIME=first-adapter
# GRAFT_OPS_CONTAINER_DOCKER_ENDPOINT=unix:///var/run/docker.sock
# GRAFT_OPS_CONTAINER_LOGS_DEFAULT_TAIL=200
# GRAFT_OPS_CONTAINER_LOGS_MAX_TAIL=2000
# GRAFT_OPS_CONTAINER_ACTIONS_DANGEROUS_ENABLED=false
# GRAFT_OPS_CONTAINER_SHELL_ENABLED=false

# Required only when container shell is enabled; list browser origins allowed to open shell WebSocket sessions.
# GRAFT_HTTPX_WEBSOCKET_ALLOWED_ORIGINS=
